{% comment %}
  Main Collection Product Grid Section
{% endcomment %}

<style>
  .collection-toolbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--spacing-md) 0;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--spacing-lg);
  }

  .grid-controls {
    display: flex;
    gap: 10px;
  }

  .grid-btn {
    background: none;
    border: 1px solid #DDD;
    padding: 5px 10px;
    cursor: pointer;
    font-size: 0.8rem;
  }

  .grid-btn--active {
    background-color: var(--color-accent);
    color: white;
    border-color: var(--color-accent);
  }

  .product-grid {
    display: grid;
    gap: var(--spacing-lg) var(--spacing-md);
    transition: all 0.3s ease;
  }

  /* Grid States */
  .product-grid--2 { grid-template-columns: repeat(2, 1fr); }
  .product-grid--3 { grid-template-columns: repeat(3, 1fr); }
  .product-grid--4 { grid-template-columns: repeat(4, 1fr); }

  @media (max-width: 768px) {
    .product-grid--3, .product-grid--4 { grid-template-columns: repeat(2, 1fr); }
  }
</style>

<div class="main-collection container">
  <div class="collection-toolbar">
    <div class="collection-info">
      <h1>{{ collection.title }}</h1>
      <p>{{ collection.products_count }} Products</p>
    </div>

    <div class="grid-controls">
      <button class="grid-btn" onclick="setGridCol(2)">2</button>
      <button class="grid-btn grid-btn--active" onclick="setGridCol(3)">3</button>
      <button class="grid-btn" onclick="setGridCol(4)">4</button>
    </div>
  </div>

  <div id="ProductGrid" class="product-grid product-grid--3">
    {% for product in collection.products %}
      {% render 'product-card', product: product %}
    {% endfor %}
  </div>
</div>

<script>
  function setGridCol(cols) {
    const grid = document.getElementById('ProductGrid');
    const btns = document.querySelectorAll('.grid-btn');
    
    // Update Grid Class
    grid.classList.remove('product-grid--2', 'product-grid--3', 'product-grid--4');
    grid.classList.add(`product-grid--${cols}`);
    
    // Update Button State
    btns.forEach(btn => {
      btn.classList.remove('grid-btn--active');
      if(btn.innerText == cols) btn.classList.add('grid-btn--active');
    });
  }
</script>

{% schema %}
{
  "name": "Product Grid",
  "settings": []
}
{% endschema %}
