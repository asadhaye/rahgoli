{% comment %}
  Simple CSS-only Category Carousel
{% endcomment %}

<style>
  .category-carousel {
    padding: var(--spacing-lg) 0;
  }

  .category-carousel__heading {
    text-align: center;
    margin-bottom: var(--spacing-lg);
  }

  .category-grid {
    display: flex;
    gap: var(--spacing-md);
    overflow-x: auto;
    padding-bottom: var(--spacing-md);
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .category-grid::-webkit-scrollbar {
    display: none;
  }

  .category-item {
    flex: 0 0 calc(25% - var(--spacing-md));
    min-width: 250px;
    text-align: center;
  }

  .category-item__image {
    width: 100%;
    aspect-ratio: 4/5;
    background-color: #F5F5F5;
    object-fit: cover;
    margin-bottom: var(--spacing-sm);
    transition: transform 0.5s ease;
  }

  .category-item:hover .category-item__image {
    transform: scale(1.05);
  }

  .category-item__title {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  @media (max-width: 768px) {
    .category-item {
      flex: 0 0 70%;
    }
  }
</style>

<div class="category-carousel container">
  <div class="category-carousel__heading">
    <h2>Shop By Category</h2>
  </div>
  
  <div class="category-grid">
    {% for collection in collections %}
      <a href="{{ collection.url }}" class="category-item">
        {% if collection.featured_image %}
          <img src="{{ collection.featured_image | image_url: width: 600 }}" class="category-item__image" alt="{{ collection.title }}">
        {% else %}
          <div class="category-item__image"></div>
        {% endif %}
        <div class="category-item__title">{{ collection.title }}</div>
      </a>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Category Carousel",
  "settings": [],
  "presets": [
    {
      "name": "Category Carousel"
    }
  ]
}
{% endschema %}
